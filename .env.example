# Banco / Postgres (estado funcional atual do ambiente dev)
PGDATABASE=portal
PGUSER=portal
PGPASSWORD=portaldev
PGPORT_MAP=5432

# Para BFF em Docker Compose, o host correto do banco é o serviço "postgres"
DATABASE_URL=postgresql://portal:portaldev@postgres:5432/portal

# BFF / Sessão / CORS
SESSION_SECRET=dev-secret
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Expresso / envio de e-mail
EXPRESSO_MAIL_ENABLED=true
EXPRESSO_API_BASE=https://api.expresso.pr.gov.br/celepar
EXPRESSO_API_USER=plataforma.agepar
EXPRESSO_API_PASSWORD=Agepar2026
EXPRESSO_MAIL_TIMEOUT_SECONDS=10
EXPRESSO_MAIL_AUTH_CACHE_SECONDS=600

# Portal / links públicos
PORTAL_PUBLIC_BASE_URL=http://10.59.1.138:5173/

# Scheduler semanal de tarefas
TASK_WEEKLY_EMAIL_SCHEDULER_ENABLED=true
TASK_WEEKLY_EMAIL_SCHEDULER_POLL_SECONDS=60

# Flags legadas/operacionais que antes vinham de infra/.env
DFD_REAJUSTE_PCA_ACTIVE=false
DFD_ACCEPTING=1

# Outras flags úteis
FERIAS_DEBUG_LOG=1
