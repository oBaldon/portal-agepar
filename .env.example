# Banco / Postgres
PGDATABASE=plataforma
PGUSER=plataforma
PGPASSWORD=plataformadev
PGPORT_MAP=5432
DATABASE_URL=postgresql://plataforma:plataformadev@localhost:5432/plataforma

# BFF / Sessão / CORS
SESSION_SECRET=troque-esta-chave
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Expresso / envio de e-mail
EXPRESSO_MAIL_ENABLED=false
EXPRESSO_API_BASE=https://api.expresso.pr.gov.br/celepar
EXPRESSO_API_USER=preencha-seu-usuario
EXPRESSO_API_PASSWORD=preencha-sua-senha
EXPRESSO_MAIL_TIMEOUT_SECONDS=10
EXPRESSO_MAIL_AUTH_CACHE_SECONDS=600

# Portal / links públicos
PORTAL_PUBLIC_BASE_URL=http://localhost:5173/

# Scheduler semanal de tarefas
TASK_WEEKLY_EMAIL_SCHEDULER_ENABLED=false
TASK_WEEKLY_EMAIL_SCHEDULER_POLL_SECONDS=60

# Outras flags úteis
FERIAS_DEBUG_LOG=1